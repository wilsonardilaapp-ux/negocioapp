
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // 1. REGLAS PÚBLICAS (ACCESO TOTAL SIN LOGIN)
    // ============================================
    
    // Configuración de alias y compartir (Necesario para collectionGroup)
    match /{path=**}/shareConfig/{docId} {
      allow read, list: if true;
    }

    // Datos del catálogo y landing (Subcolecciones públicas)
    match /businesses/{businessId}/publicData/{docId} {
      allow read: if true;
    }
    
    match /businesses/{businessId}/landingPages/{docId} {
      allow read: if true;
    }

    // Listado de productos (Si se consultan directamente)
    match /businesses/{businessId}/products/{productId} {
      allow read: if true; 
    }

    // Promociones públicas
    match /promotions/{promotionId} {
      allow read, list: if resource.data.showInCatalog == true;
    }

    // Cupones (Lectura pública para validación en carrito)
    match /cupones/{couponId} {
      allow read, list: if true;
    }

    // Métodos de pago y planes
    match /paymentSettings/{userId} {
      allow get: if true;
    }

    match /plans/{planId} {
      allow read: if true;
    }

    match /globalConfig/{document=**} {
      allow read: if true;
    }

    // Blog público
    match /blog_posts/{postId} {
      allow get: if true;
      allow list: if resource.data.isActive == true;
    }

    // Pedidos y Contacto (Permitir que cualquiera envíe datos)
    match /businesses/{businessId}/orders/{orderId} {
      allow create: if true;
    }

    match /businesses/{businessId}/contactSubmissions/{submissionId} {
      allow create: if true;
    }

    match /contactMessages/{messageId} {
      allow create: if true;
    }

    // ============================================
    // 2. FUNCIONES DE AYUDA (PARA ADMINS/DUEÑOS)
    // ============================================

    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return request.auth != null && exists(userDocPath());
    }

    function userData() {
      return get(userDocPath()).data;
    }

    function isSuperAdmin() {
      return userExists() && userData().role == 'super_admin';
    }

    function isBusinessMember(businessId) {
      return request.auth != null && (request.auth.uid == businessId || (userExists() && 'businessId' in userData() && userData().businessId == businessId));
    }

    // ============================================
    // 3. REGLAS PRIVADAS (SOLO AUTENTICADOS)
    // ============================================

    // Usuarios
    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      allow list, delete: if isSuperAdmin();
    }

    // Negocios y subcolecciones privadas
    match /businesses/{businessId} {
      allow get: if true;
      allow list, update, delete: if isBusinessMember(businessId) || isSuperAdmin();

      match /contactForms/{formId} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /suggestionRules/{ruleId} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /notifications/{notificationId} { allow read, update, delete: if isBusinessMember(businessId) || isSuperAdmin(); allow create: if isSuperAdmin(); }
      match /chatbotConfig/{doc=**} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /chatConversations/{doc=**} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /backups/{doc=**} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /kardexConfig/{doc=**} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /reminders/{doc=**} { allow read, write: if isSuperAdmin(); }
      match /shareConfig/{docId} { allow write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /orders/{docId} { allow read, update, delete: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /contactSubmissions/{docId} { allow read, update, delete: if isBusinessMember(businessId) || isSuperAdmin(); }
    }

    // Recursos del sistema
    match /modules/{moduleId} { allow read: if true; allow write: if isSuperAdmin(); }
    match /systemServices/{serviceId} { allow read: if request.auth != null; allow write: if isSuperAdmin(); }
    match /integrations/{integrationId} { allow read: if request.auth != null; allow write: if isSuperAdmin(); }
    match /contactMessages/{messageId} { allow read, update, delete: if isSuperAdmin(); }

    // Por defecto denegar todo lo demás
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
