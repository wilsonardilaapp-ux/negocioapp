
rules_version = '2';

service cloud.firestore {
    match /databases/{database}/documents {
        
            function isSuperAdmin() {
                    // Efficiently check if the user exists and has the 'super_admin' role.
                          let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
                                return request.auth != null && exists(userDocPath) && get(userDocPath).data.role == 'super_admin';
            }
              
                  function isBusinessMember(businessId) {
                          // A more robust check for business membership.
                                // First, check for direct ownership which is most common and doesn't require a 'get'.
                                      // Then, check for staff membership safely using 'exists'.
                                            let userDocPath = /databases/$(database)/documents/users/$(request.auth.uid);
                                                  return request.auth != null && (
                                                            request.auth.uid == businessId ||
                                                                    (exists(userDocPath) && get(userDocPath).data.businessId == businessId)
                                                  );
                  }
                      
                          // NEW: Allow public read access to the 'shareConfig' collection group.
                              // This is necessary for resolving custom catalog slugs.
                                  match /{path=**}/shareConfig/{docId} {
                                          allow read: if true;
                                  }

                                      // This rule allows superadmins to manage all scheduled reminders across all clients.
                                          // The collectionGroup query in the app relies on this rule.
                                              match /{path=**}/reminders/{reminderId} {
                                                      allow read, write, create, update, delete, list: if isSuperAdmin();
                                              }

                                                  // Publicly readable collections
                                                      match /blog_posts/{postId} {
                                                              allow get, list: if true;
                                                                    allow create: if request.auth != null && 
                                                                                        (request.resource.data.businessId == request.auth.uid || isSuperAdmin());
                                                                                              allow update, delete: if request.auth != null && (
                                                                                                        resource.data.businessId == request.auth.uid || isSuperAdmin()
                                                                                              );
                                                      }
                                                          match /plans/{planId} {
                                                                  allow read: if true;
                                                                        allow write: if isSuperAdmin();
                                                          }
                                                              match /globalConfig/{document=**} {
                                                                      allow read: if true;
                                                                            allow write: if isSuperAdmin();
                                                              }
                                                                  match /settings/{document=**} {
                                                                          allow read: if true;
                                                                                allow write: if isSuperAdmin();
                                                                  }
                                                                      match /landing_configs/{docId} {
                                                                              allow read: if true;
                                                                                    allow write: if isSuperAdmin();
                                                                      }

                                                                          // User-specific data
                                                                              match /users/{userId} {
                                                                                      allow get, update: if request.auth.uid == userId;
                                                                                            allow list: if request.auth != null;
                                                                                                  allow create, delete, write: if isSuperAdmin();
                                                                              }
                                                                                  match /paymentSettings/{userId} {
                                                                                          allow read, write: if request.auth.uid == userId;
                                                                                  }

                                                                                      // Business-related data
                                                                                          match /businesses/{businessId} {
                                                                                                  allow get: if true;
                                                                                                        allow list: if request.auth != null;
                                                                                                              allow write: if isSuperAdmin();
                                                                                                                    allow create, update, delete: if isBusinessMember(businessId);

                                                                                                                          // Publicly readable subcollections
                                                                                                                                match /publicData/{docId=**} {
                                                                                                                                          allow read: if true;
                                                                                                                                                  allow write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                }
                                                                                                                                      match /landingPages/{pageId} {
                                                                                                                                                allow read: if true;
                                                                                                                                                        allow write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                      }
                                                                                                                                             match /landingConfig/{docId=**} {
                                                                                                                                                      allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                             }

                                                                                                                                                   // Private subcollections
                                                                                                                                                         match /products/{productId} {
                                                                                                                                                                  allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                         }
                                                                                                                                                               match /orders/{orderId} {
                                                                                                                                                                        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                               }
                                                                                                                                                                     match /contactForms/{formId} {
                                                                                                                                                                              allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                     }
                                                                                                                                                                           match /contactSubmissions/{submissionId} {
                                                                                                                                                                                    allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                           }
                                                                                                                                                                                 match /suggestionRules/{ruleId} {
                                                                                                                                                                                          allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                 }
                                                                                                                                                                                       match /printers/{printerId} {
                                                                                                                                                                                                allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                       }
                                                                                                                                                                                             match /invoiceSettings/{docId} {
                                                                                                                                                                                                       allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                             }
                                                                                                                                                                                                   match /subscription/{docId} {
                                                                                                                                                                                                            allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                   }
                                                                                                                                                                                                         match /shareConfig/{docId} {
                                                                                                                                                                                                                  // This rule remains for direct access and write control
                                                                                                                                                                                                                          allow read: if true;
                                                                                                                                                                                                                                  allow write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                         }
                                                                                                                                                                                                               match /backups/{backupId} {
                                                                                                                                                                                                                        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                               }
                                                                                                                                                                                                                     match /backupSchedules/{scheduleId} {
                                                                                                                                                                                                                              allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                     }
                                                                                                                                                                                                                           match /kardexConfig/{docId} {
                                                                                                                                                                                                                                    allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                           }
                                                                                                                                                                                                                                 match /kardexItems/{itemId} {
                                                                                                                                                                                                                                          allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                 }
                                                                                                                                                                                                                                       match /kardexMovimientos/{movimientoId} {
                                                                                                                                                                                                                                                allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                       }
                                                                                                                                                                                                                                             
                                                                                                                                                                                                                                                   // Notification Rules
                                                                                                                                                                                                                                                         match /notifications/{notificationId} {
                                                                                                                                                                                                                                                                  allow read, update: if isBusinessMember(businessId);
                                                                                                                                                                                                                                                                          allow create: if isSuperAdmin();
                                                                                                                                                                                                                                                                                  allow delete: if isBusinessMember(businessId);
                                                                                                                                                                                                                                                         }

                                                                                                                                                                                                                                                               // Contabilidad
                                                                                                                                                                                                                                                                     match /asientos/{asientoId} {
                                                                                                                                                                                                                                                                              allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                           match /cuentas/{cuentaId} {
                                                                                                                                                                                                                                                                                    allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                                                           }
                                                                                                                                                                                                                                                                                 match /activosFijos/{activoId} {
                                                                                                                                                                                                                                                                                          allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                                                                 }
                                                                                                                                                                                                                                                                                       match /impuestos/{impuestoId} {
                                                                                                                                                                                                                                                                                                allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                                                                       }
                                                                                                                                                                                                                                                                                             match /declaracionesImpuestos/{declaracionId} {
                                                                                                                                                                                                                                                                                                      allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                                                                   
                                                                                                                                                                                                                                                                                                         // Chatbot specific rules
                                                                                                                                                                                                                                                                                                               match /chatbotConfig/main {
                                                                                                                                                                                                                                                                                                                        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                                                                                                                match /knowledgeBase/{documentId} {
                                                                                                                                                                                                                                                                                                                                              allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                               }
                                                                                                                                                                                                                                                                                                                     match /chatConversations/{conversationId} {
                                                                                                                                                                                                                                                                                                                                allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                                                                                                                          match /messages/{messageId} {
                                                                                                                                                                                                                                                                                                                                                          allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                                                                                                                          }
                                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                                                           match /services/{serviceId} {
                                                                                                                                                                                                                                                                                                                                    allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                                                                                                           }
                                                                                                                                                                                                                                                                                                                                 match /modules/{moduleId} {
                                                                                                                                                                                                                                                                                                                                          allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
                                                                                                                                                                                                                                                                                                                                 }
                                                                                          }
                                                                                              
                                                                                                  // System-level collections
                                                                                                      match /modules/{moduleId} {
                                                                                                              allow read: if true;
                                                                                                                    allow write: if isSuperAdmin();
                                                                                                      }
                                                                                                          match /systemServices/{serviceId} { 
                                                                                                                  // Any authenticated user can read system services (e.g., to check limits).
                                                                                                                        allow read: if request.auth != null;
                                                                                                                              allow write: if isSuperAdmin();
                                                                                                          }
                                                                                                              match /integrations/{integrationId} {
                                                                                                                      allow read: if request.auth != null;
                                                                                                                            allow write: if isSuperAdmin();
                                                                                                              }
                                                                                                                  
                                                                                                                      // NEW: Messages from contact forms and client replies
                                                                                                                          match /contactMessages/{messageId} {
                                                                                                                                  allow read, update, delete: if isSuperAdmin();
                                                                                                                                        // Allow unauthenticated (for webform) and authenticated (for client reply) to create.
                                                                                                                                              allow create: if true;

                                                                                                                                                    // Replies by superadmin to a public user's message
                                                                                                                                                          match /replies/{replyId} {
                                                                                                                                                                    allow read, create: if isSuperAdmin();
                                                                                                                                                          }
                                                                                                                          }
                                                                                                                              
                                                                                                                                  // Default deny all other paths. This is a security best practice.
                                                                                                                                      match /{document=**} { 
                                                                                                                                              allow read, write: if false; 
                                                                                                                                      }
    }
}
                                                                                                                                      }
                                                                                                                                                          }
                                                                                                                          }
                                                                                                              }
                                                                                                          }
                                                                                                      }
                                                                                                                                                                                                                                                                                                                                 }
                                                                                                                                                                                                                                                                                                                           }
                                                                                                                                                                                                                                                                                                                                          }
                                                                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                                                                               }
                                                                                                                                                                                                                                                                                             }
                                                                                                                                                                                                                                                                                       }
                                                                                                                                                                                                                                                                                 }
                                                                                                                                                                                                                                                                           }
                                                                                                                                                                                                                                                                     }
                                                                                                                                                                                                                                                         }
                                                                                                                                                                                                                                       }
                                                                                                                                                                                                                                 }
                                                                                                                                                                                                                           }
                                                                                                                                                                                                                     }
                                                                                                                                                                                                               }
                                                                                                                                                                                                         }
                                                                                                                                                                                                   }
                                                                                                                                                                                             }
                                                                                                                                                                                       }
                                                                                                                                                                                 }
                                                                                                                                                                           }
                                                                                                                                                                     }
                                                                                                                                                               }
                                                                                                                                                         }
                                                                                                                                             }
                                                                                                                                      }
                                                                                                                                }
                                                                                          }
                                                                                  }
                                                                              }
                                                                      }
                                                                  }
                                                              }
                                                          }
                                                                                              )
                                                      }
                                              }
                                  }
                                                  )
                  }
            }
    }
}
