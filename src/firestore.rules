
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return isAuthenticated() && (
        request.auth.token.email == 'allseosoporte@gmail.com' ||
        request.auth.token.email == 'admin@zentry.com' ||
        request.auth.token.email == 'admin@ecosalud.com' ||
        request.auth.token.email == 'alexjfweb@gmail.com'
      );
    }

    function isSuperAdmin() {
      return isAdminEmail() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
      );
    }

    function isOwner(businessId) {
      return isAuthenticated() && (
        request.auth.uid == businessId || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId)
      );
    }

    function isBusinessMember(businessId) {
      return isOwner(businessId);
    }

    // --- REGLAS PÚBLICAS CRÍTICAS ---
    
    match /{path=**}/shareConfig/{docId} {
      allow read, list: if true;
    }

    match /paymentSettings/{userId} {
      allow read: if true;
      allow write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    match /promotions/{promoId} {
      allow read, list: if true;
      allow write: if isSuperAdmin() || isOwner(request.resource.data.companyId || resource.data.companyId);
    }

    match /cupones/{couponId} {
      allow read, list: if true;
      allow write: if isSuperAdmin() || isOwner(request.resource.data.businessId || resource.data.businessId);
    }

    match /blog_posts/{postId} {
      // CRÍTICO: Se requiere 'list' para que el dashboard pueda contar los posts y validar límites
      allow read, list: if true;
      allow write: if isSuperAdmin() || isOwner(request.resource.data.businessId || resource.data.businessId);
    }

    // --- VALORACIONES DEL DIRECTORIO ---
    match /directoryRatings/{ratingId} {
      // Cualquier usuario puede ver valoraciones publicadas
      allow read, list: if resource.data.status == 'published' || isSuperAdmin() || isOwner(resource.data.businessId);
      // Usuarios autenticados pueden crear valoraciones
      allow create: if isAuthenticated();
      // Solo el superadmin o el dueño del negocio pueden actualizar (para respuestas)
      allow update: if isSuperAdmin() || isOwner(resource.data.businessId);
      // Solo el superadmin puede eliminar
      allow delete: if isSuperAdmin();
    }

    // --- REGLAS POR COLECCIÓN ---

    // Directorio Unificado (en la colección businesses)
    match /businesses/{businessId} {
      // Lectura pública permitida para el directorio
      allow get, list: if true;
      
      // Escritura restringida
      allow write: if isSuperAdmin() || isBusinessMember(businessId);

      match /publicData/{docId=**} {
        allow read, list: if true;
        allow write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      match /landingPages/{pageId} {
        allow read, list: if true;
        allow write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      match /products/{productId} {
        allow read, list: if true;
        allow write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      match /orders/{orderId} {
        allow create: if true;
        allow read, update, delete: if isSuperAdmin() || isBusinessMember(businessId);
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if isSuperAdmin() || isBusinessMember(businessId);
        allow create: if isSuperAdmin();
      }

      match /{allSubcollections=**} {
        allow read, write: if isSuperAdmin() || isBusinessMember(businessId);
      }
    }

    // --- REGLAS OBSOLETAS (MIGRACIÓN) ---
    match /businessDirectory/{entryId} {
      allow read, list: if true;
      allow write: if isSuperAdmin();
    }

    match /directoryAds/{adId} {
      allow read, list: if true;
      allow write: if isSuperAdmin();
    }

    // Planes y Configuración
    match /hybrid_plans/{planId} { allow read, list: if true; allow write: if isSuperAdmin(); }
    match /plans/{planId} { allow read, list: if true; allow write: if isSuperAdmin(); }
    match /globalConfig/{document=**} { allow read, list: if true; allow write: if isSuperAdmin(); }

    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, write: if isSuperAdmin();
    }

    // --- REGLA POR DEFECTO ---
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
