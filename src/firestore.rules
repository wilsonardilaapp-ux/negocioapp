
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Cached user document path
    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return request.auth != null && exists(userDocPath());
    }

    function userData() {
      return get(userDocPath()).data;
    }

    function isSuperAdmin() {
      return userExists() && userData().role == 'super_admin';
    }

    function isBusinessMember(businessId) {
      return request.auth.uid == businessId || (userExists() && userData().businessId == businessId);
    }

    function isOwner(businessId) {
      return request.auth != null && (request.auth.uid == businessId || (userExists() && userData().businessId == businessId));
    }

    // Promotions Rules
    match /promotions/{promotionId} {
      allow read: if resource.data.showInCatalog == true
        || (request.auth != null && (
          isSuperAdmin() ||
          isOwner(resource.data.companyId)
        ));

      allow create: if request.auth != null && (
        isSuperAdmin() ||
        userData().businessId == request.resource.data.companyId ||
        request.auth.uid == request.resource.data.companyId
      );

      allow update, delete: if request.auth != null && (
        isSuperAdmin() ||
        isOwner(resource.data.companyId)
      );
    }

    // Existing Rules (Rest omitted for brevity in explanation, but full file provided below)
    match /{path=**}/shareConfig/{docId} { allow read: if true; }
    match /{path=**}/reminders/{reminderId} { allow read, create, update, delete, list: if isSuperAdmin(); }
    match /blog_posts/{postId} { allow get, list: if true; allow create, update, delete: if request.auth != null; }
    match /plans/{planId} { allow read: if true; allow write: if isSuperAdmin(); }
    match /globalConfig/{document=**} { allow read: if true; allow write: if request.auth != null; }
    match /users/{userId} { allow get: if request.auth != null; allow create: if request.auth != null; allow update: if request.auth != null; allow list, delete: if isSuperAdmin(); }
    match /paymentSettings/{userId} { allow get: if true; allow write: if request.auth != null; }
    match /businesses/{businessId} {
      allow get: if true; allow list: if request.auth != null;
      allow create, update, delete: if isBusinessMember(businessId) || isSuperAdmin();
      match /{allSubcollections=**} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /contactSubmissions/{submissionId} { allow create: if true; }
    }
    match /contactMessages/{messageId} { allow read, update, delete: if isSuperAdmin(); allow create: if true; }
  }
}
