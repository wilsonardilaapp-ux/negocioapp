
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return isAuthenticated() && (
        request.auth.token.email == 'allseosoporte@gmail.com' ||
        request.auth.token.email == 'admin@zentry.com' ||
        request.auth.token.email == 'admin@ecosalud.com' ||
        request.auth.token.email == 'alexjfweb@gmail.com'
      );
    }

    function isSuperAdmin() {
      return isAdminEmail() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
      );
    }

    function isOwner(businessId) {
      return isAuthenticated() && (
        request.auth.uid == businessId || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId)
      );
    }

    function isBusinessMember(businessId) {
      return isOwner(businessId);
    }

    // --- REGLAS PÚBLICAS CRÍTICAS ---
    
    match /modules/{moduleId} {
      allow read: if true;
    }

    match /systemServices/{serviceId} {
      allow read: if true;
    }

    match /{path=**}/shareConfig/{docId} {
      allow read, list: if true;
    }

    match /paymentSettings/{userId} {
      allow read: if true;
      allow write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    match /promotions/{promoId} {
      allow read, list: if true;
      allow create, update: if isSuperAdmin() || isOwner(request.resource.data.companyId);
      allow delete: if isSuperAdmin() || isOwner(resource.data.companyId);
    }

    match /cupones/{couponId} {
      allow read, list: if true;
      // Corregido: Separar create/update de delete para evitar error de resource null
      allow create, update: if isSuperAdmin() || isOwner(request.resource.data.businessId);
      allow delete: if isSuperAdmin() || isOwner(resource.data.businessId);
    }

    match /blog_posts/{postId} {
      allow read, list: if true;
      allow create, update: if isSuperAdmin() || isOwner(request.resource.data.businessId);
      allow delete: if isSuperAdmin() || isOwner(resource.data.businessId);
    }

    // --- PROGRAMA DE SOCIOS (REFERIDOS) ---

    match /referrals/{id} {
      allow list: if isSuperAdmin();
      allow get: if isAuthenticated() && (
        isSuperAdmin() ||
        resource.data.referentBusinessId == request.auth.uid ||
        resource.data.referreeBusinessId == request.auth.uid
      );
      allow create: if isAuthenticated();
      allow update, delete: if isSuperAdmin();
    }

    match /extraCapacityLogs/{id} {
      allow list: if isSuperAdmin();
      allow get: if isAuthenticated() && (
        isSuperAdmin() || 
        resource.data.businessId == request.auth.uid
      );
      allow write: if isSuperAdmin();
    }

    match /adminConfig/affiliates {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // --- VALORACIONES DEL DIRECTORIO ---
    match /directoryRatings/{ratingId} {
      allow read, list: if resource.data.status == 'published' || isSuperAdmin() || isOwner(resource.data.businessId);
      
      allow create: if (isAuthenticated() && request.resource.data.authType == 'registered') || (
        request.resource.data.authType == 'guest' &&
        request.resource.data.status == 'pending' &&
        request.resource.data.guestName != "" &&
        request.resource.data.guestPhone != "" &&
        !('adminResponse' in request.resource.data) &&
        !('businessResponse' in request.resource.data)
      );
      
      allow update: if isSuperAdmin() || isOwner(resource.data.businessId);
      allow delete: if isSuperAdmin();
    }

    // --- REGLAS POR COLECCIÓN ---

    match /businesses/{businessId} {
      allow get, list: if true;
      allow write: if isSuperAdmin() || isBusinessMember(businessId);

      match /publicData/{docId=**} {
        allow read, list: if true;
        allow write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      match /landingPages/{pageId} {
        allow read, list: if true;
        allow write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      match /products/{productId} {
        allow read, list: if true;
        allow write: if isSuperAdmin() || isBusinessMember(businessId);

        match /votes/{visitorId} {
          allow read: if true;
          allow create: if true;
          allow update, delete: if false;
        }
      }

      match /orders/{orderId} {
        allow create: if true;
        allow read, update, delete: if isSuperAdmin() || isBusinessMember(businessId);
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if isSuperAdmin() || isBusinessMember(businessId);
        allow create: if isSuperAdmin() || isBusinessMember(businessId);
      }

      // --- MÓDULO DE RESEÑAS Y FIDELIZACIÓN ---

      match /reviews/{reviewId} {
        allow read: if resource.data.status == 'approved' || isBusinessMember(businessId) || isSuperAdmin();
        allow create: if true && (
          (isBusinessMember(businessId) || isSuperAdmin()) || 
          (!('reply' in request.resource.data) && (!('status' in request.resource.data) || request.resource.data.status != 'approved'))
        );
        allow update, delete: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /loyaltyBalances/{whatsapp} {
        allow get: if true;
        allow list: if isBusinessMember(businessId) || isSuperAdmin();
        allow write: if false;
      }

      match /loyaltyTransactions/{transactionId} {
        allow get: if true;
        allow list: if isBusinessMember(businessId) || isSuperAdmin();
        allow write: if false;
      }

      match /rewards/{rewardId} {
        allow read: if resource.data.isActive == true || isBusinessMember(businessId) || isSuperAdmin();
        allow write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /productAlerts/{alertId} {
        allow read, write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      match /publicMenuChatbot/main {
        allow read: if true;
        allow write: if isSuperAdmin() || isBusinessMember(businessId);

        match /responses/{responseId} {
          allow read: if true;
          allow write: if isSuperAdmin() || isBusinessMember(businessId);
        }

        match /conversations/{convId} {
          allow create: if true;
          allow read, write: if isSuperAdmin() || isBusinessMember(businessId);
        }
      }

      match /{allSubcollections=**} {
        allow read, write: if isSuperAdmin() || isBusinessMember(businessId);
      }
    }

    match /hybrid_plans/{planId} { allow read, list: if true; allow write: if isSuperAdmin(); }
    match /plans/{planId} { allow read, list: if true; allow write: if isSuperAdmin(); }
    match /globalConfig/{document=**} { allow read, list: if true; allow write: if isSuperAdmin(); }

    match /users/{userId} {
      allow get: if isAuthenticated() && (request.auth.uid == userId || isSuperAdmin());
      allow list: if isSuperAdmin();
      allow write: if isSuperAdmin() || (isAuthenticated() && request.auth.uid == userId);
    }

    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, write: if isSuperAdmin();
    }
    
    match /paymentRequests/{requestId} {
      allow create: if isAuthenticated();
      allow read, write: if isSuperAdmin();
    }

    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
