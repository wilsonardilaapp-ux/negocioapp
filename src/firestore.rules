
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Funciones de ayuda
    function userDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function userExists() {
      return request.auth != null && exists(userDocPath());
    }

    function userData() {
      return get(userDocPath()).data;
    }

    function isSuperAdmin() {
      return userExists() && userData().role == 'super_admin';
    }

    function isBusinessMember(businessId) {
      return request.auth.uid == businessId || (userExists() && 'businessId' in userData() && userData().businessId == businessId);
    }

    function isOwner(businessId) {
      return request.auth != null && (request.auth.uid == businessId || (userExists() && 'businessId' in userData() && userData().businessId == businessId));
    }

    // REGLAS PÚBLICAS (Accesibles sin estar registrado)
    
    // Permitir leer la configuración de compartir (necesario para alias personalizados)
    match /{path=**}/shareConfig/{docId} {
      allow read: if true;
    }

    // Permitir leer datos públicos de negocios (Catálogo y Landing)
    match /businesses/{businessId}/publicData/{docId} {
      allow read: if true;
    }
    
    match /businesses/{businessId}/landingPages/{docId} {
      allow read: if true;
    }

    match /blog_posts/{postId} {
      allow get: if true;
      allow list: if resource.data.isActive == true || (request.auth != null && (request.auth.uid == resource.data.businessId || isSuperAdmin()));
    }

    match /promotions/{promotionId} {
      allow read: if resource.data.showInCatalog == true || (request.auth != null && (isSuperAdmin() || isOwner(resource.data.companyId)));
    }

    match /cupones/{couponId} {
      allow read: if true;
    }

    match /plans/{planId} {
      allow read: if true;
    }

    match /globalConfig/{document=**} {
      allow read: if true;
    }

    // REGLAS PRIVADAS Y OPERACIONALES

    // Pedidos (Permitir creación pública, lectura solo dueños)
    match /businesses/{businessId}/orders/{orderId} {
      allow create: if true;
      allow read, update, delete: if isBusinessMember(businessId) || isSuperAdmin();
    }

    // Envíos de formulario (Públicos)
    match /businesses/{businessId}/contactSubmissions/{submissionId} {
      allow create: if true;
      allow read, update, delete: if isBusinessMember(businessId) || isSuperAdmin();
    }

    // Usuarios
    match /users/{userId} {
      allow get: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      allow update: if request.auth != null && (request.auth.uid == userId || isSuperAdmin())
        && request.resource.data.role == resource.data.role
        && request.resource.data.businessId == resource.data.businessId;
      allow list: if isSuperAdmin();
      allow create: if request.auth != null && request.auth.uid == userId;
      allow delete: if isSuperAdmin();
    }

    // Configuración de pagos
    match /paymentSettings/{userId} {
      allow get: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Estructura general de Negocios
    match /businesses/{businessId} {
      allow get: if true;
      allow list: if request.auth != null;
      allow create, update, delete: if isBusinessMember(businessId) || isSuperAdmin();

      match /products/{productId} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /contactForms/{formId} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /suggestionRules/{ruleId} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /notifications/{notificationId} { allow read, update, delete: if isBusinessMember(businessId) || isSuperAdmin(); allow create: if isSuperAdmin(); }
      match /chatbotConfig/{doc=**} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /chatConversations/{doc=**} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /services/{doc=**} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /modules/{doc=**} { allow read, write: if isBusinessMember(businessId) || isSuperAdmin(); }
      match /reminders/{doc=**} { allow read, write: if isSuperAdmin(); }
    }

    // Mensajes de contacto globales
    match /contactMessages/{messageId} {
      allow read, update, delete: if isSuperAdmin();
      allow create: if true;
    }

    // Otros recursos del sistema
    match /modules/{moduleId} { allow read: if true; allow write: if isSuperAdmin(); }
    match /systemServices/{serviceId} { allow read: if request.auth != null; allow write: if isSuperAdmin(); }
    match /integrations/{integrationId} { allow read: if request.auth != null; allow write: if isSuperAdmin(); }

    // Por defecto denegar
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
