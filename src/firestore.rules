
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNCIONES DE SEGURIDAD ---

    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdminEmail() {
      return isAuthenticated() && (
        request.auth.token.email == 'allseosoporte@gmail.com' ||
        request.auth.token.email == 'admin@zentry.com'
      );
    }

    function isSuperAdmin() {
      // Priorizar el check por email para evitar llamadas a get() y posibles recursiones
      return isAdminEmail() || (
        isAuthenticated() && 
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin'
      );
    }

    function isOwner(businessId) {
      return isAuthenticated() && (
        request.auth.uid == businessId || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId)
      );
    }

    function isBusinessMember(businessId) {
      return isOwner(businessId);
    }

    // --- REGLAS POR COLECCIÓN ---

    // Planes Híbridos (Menfy)
    match /hybrid_plans/{planId} {
      allow read, list: if true;
      allow write: if isSuperAdmin();
    }

    // Planes Estándar
    match /plans/{planId} {
      allow read, list: if true;
      allow write: if isSuperAdmin();
    }

    // Configuración Global
    match /globalConfig/{document=**} {
      allow read, list: if true;
      allow write: if isSuperAdmin();
    }

    // Usuarios y Perfiles
    match /users/{userId} {
      // El usuario puede leer su propio perfil sin llamar a isSuperAdmin para evitar recursión
      allow get: if isAuthenticated() && request.auth.uid == userId;
      // Los admins pueden hacer todo
      allow get, list, write: if isSuperAdmin();
      // Permitir creación inicial durante el registro
      allow create: if isAuthenticated() && request.auth.uid == userId;
    }

    // Configuración de Pago por Usuario
    match /paymentSettings/{userId} {
      allow get: if true;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Negocios y sus recursos
    match /businesses/{businessId} {
      allow get, list: if true;
      allow write: if isSuperAdmin() || isBusinessMember(businessId);

      // Datos públicos del negocio
      match /publicData/{docId=**} {
        allow read, list: if true;
        allow write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      // Landing Pages del negocio
      match /landingPages/{pageId} {
        allow read, list: if true;
        allow write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      // Productos
      match /products/{productId} {
        allow read, list: if true;
        allow write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      // Pedidos
      match /orders/{orderId} {
        allow create: if true; // Permitir que cualquiera cree un pedido (cliente final)
        allow read, update, delete: if isSuperAdmin() || isBusinessMember(businessId);
      }

      // Mensajes de contacto y notificaciones
      match /contactSubmissions/{submissionId} {
        allow create: if true;
        allow read, write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if isSuperAdmin() || isBusinessMember(businessId);
        allow create: if isSuperAdmin();
      }

      // Otros recursos del negocio
      match /{allSubcollections=**} {
        allow read, write: if isSuperAdmin() || isBusinessMember(businessId);
      }
    }

    // Mensajes de contacto globales (Bandeja SuperAdmin)
    match /contactMessages/{messageId} {
      allow create: if true;
      allow read, write: if isSuperAdmin();
    }

    // Cupones y Promociones
    match /cupones/{couponId} {
      allow read: if true;
      allow write: if isAuthenticated(); // Se refina por lógica de negocio
    }

    match /promotions/{promotionId} {
      allow read, list: if true;
      allow write: if isAuthenticated();
    }

    // --- REGLA POR DEFECTO ---
    match /{document=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
