// ... reglas existentes ...

      match /productAlerts/{alertId} {
        allow read, write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      // --- REGLAS PARA EL CHATBOT DEL MENÚ PÚBLICO ---
      match /publicMenuChatbot/config {
        allow read: if true; // Lectura pública necesaria para el widget
        allow write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      match /publicMenuChatbot/responses/{responseId} {
        allow read: if true; // Lectura pública necesaria para las respuestas automáticas
        allow write: if isSuperAdmin() || isBusinessMember(businessId);
      }

      match /publicMenuChatbot/conversations/{convId} {
        allow create: if true; // El público puede iniciar conversaciones
        allow read, write: if isSuperAdmin() || isBusinessMember(businessId);
      }

