
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. REGLA MAESTRA PARA BLOG (Soluciona tu error)
    // Permite leer y escribir SI estás logueado.
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. CONFIGURACIÓN GLOBAL (Para que no falle el inicio)
    match /globalConfig/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Regla para la configuración de apariencia del blog
    match /settings/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Permite al usuario leer su propia configuración de pago
    match /paymentSettings/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. OTRAS REGLAS
    match /users/{userId} { allow read, write: if request.auth != null; }
    match /businesses/{userId} { allow read, write: if true; match /{d=**} { allow read, write: if true; } }
    
    match /modules/{moduleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /systemServices/{serviceId} { allow read, write: if request.auth != null; }
    match /integrations/{integrationId} { allow get, list, write: if request.auth != null; }
    
    match /{document=**} { allow read, write: if false; }
  }
}
