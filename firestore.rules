
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. REGLA MAESTRA PARA BLOG (Soluciona tu error)
    // Permite leer y escribir SI estás logueado.
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Regla para Planes de Suscripción
    match /plans/{planId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 2. CONFIGURACIÓN GLOBAL (Para que no falle el inicio)
    match /globalConfig/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Regla para la configuración de apariencia del blog
    match /settings/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Permite al usuario leer su propia configuración de pago
    match /paymentSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // 3. OTRAS REGLAS
    match /users/{userId} { 
      allow read, write: if request.auth != null; 
    }
    
    // Reglas para la colección de Negocios (Businesses)
    match /businesses/{businessId} {
      // El documento principal del negocio es público para lectura, pero solo el dueño lo puede modificar
      allow get: if true;
      allow list, create, update, delete: if request.auth != null && request.auth.uid == businessId;

      // Subcolecciones públicas (para catálogo, landing page, etc.)
      match /publicData/{docId=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == businessId;
      }
      match /landingPages/{pageId=**} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == businessId;
      }

      // Subcolecciones privadas (solo el dueño del negocio puede acceder)
      match /products/{productId=**} {
        allow read, write: if request.auth.uid == businessId;
      }
      match /orders/{orderId=**} {
        allow read, write: if request.auth.uid == businessId;
      }
      match /contactForms/{formId=**} {
        allow read, write: if request.auth.uid == businessId;
      }
      match /contactSubmissions/{submissionId=**} {
        allow read, write: if request.auth.uid == businessId;
      }
       match /chatbotConfig/{path=**} {
        allow read, write: if request.auth.uid == businessId;
      }
      match /chatConversations/{path=**} {
        allow read, write: if request.auth.uid == businessId;
      }
      match /suggestionRules/{ruleId=**} {
        allow read, write: if request.auth.uid == businessId;
      }
      match /printers/{printerId=**} {
        allow read, write: if request.auth.uid == businessId;
      }
      match /invoiceSettings/{docId=**} {
        allow read, write: if request.auth.uid == businessId;
      }
      match /subscription/{docId=**} {
        allow read, write: if request.auth.uid == businessId;
      }
    }
    
    match /modules/{moduleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /systemServices/{serviceId} { 
      allow read, write: if request.auth != null; 
    }
    match /integrations/{integrationId} { 
      allow get, list, write: if request.auth != null; 
    }
    
    match /{document=**} { 
      allow read, write: if false; 
    }
  }
}
