
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // Helper function to check if a user is an owner or a member of a business
    function isBusinessMember(businessId) {
      return request.auth != null && (
        request.auth.uid == businessId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId
      );
    }

    // Publicly readable collections
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null; // Simplistic write rule, consider refining
    }
    match /plans/{planId} {
      allow read: if true;
      allow write: if request.auth != null; // Assumes only authenticated users can modify
    }
    match /globalConfig/{document=**} {
      allow read: if true;
      allow write: if request.auth != null; // Assumes only authenticated users can modify
    }
    match /settings/{document=**} {
      allow read: if true;
      allow write: if request.auth != null; // Assumes only authenticated users can modify
    }

    // User-specific data
    match /users/{userId} { 
      allow read, write: if request.auth != null && request.auth.uid == userId; 
    }
    match /paymentSettings/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Business-related data
    match /businesses/{businessId} {
      // Public can read the main business document
      allow get: if true;
      
      // Only members of the business can write to it
      allow create, update, delete: if isBusinessMember(businessId);

      // Publicly readable subcollections
      match /publicData/{docId=**} {
        allow read: if true;
        allow write: if isBusinessMember(businessId);
      }
      match /landingPages/{pageId=**} {
        allow read: if true;
        allow write: if isBusinessMember(businessId);
      }

      // Private subcollections accessible only by business members
      match /products/{productId=**} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /orders/{orderId=**} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /contactForms/{formId=**} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /contactSubmissions/{submissionId=**} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /chatbotConfig/{path=**} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /chatConversations/{path=**} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /suggestionRules/{ruleId=**} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /printers/{printerId=**} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /invoiceSettings/{docId=**} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /subscription/{docId=**} {
        allow read, write: if isBusinessMember(businessId);
      }
    }
    
    // System-level collections (potentially admin-only)
    match /modules/{moduleId} {
      allow read: if true; // Modules are public to read
      allow write: if request.auth != null; // Simplified admin write rule
    }
    match /systemServices/{serviceId} { 
      allow read, write: if request.auth != null; // Simplified admin write rule
    }
    match /integrations/{integrationId} { 
      allow get, list, write: if request.auth != null; // Simplified admin write rule
    }
    
    // Default deny all other paths
    match /{document=**} { 
      allow read, write: if false; 
    }
  }
}

    