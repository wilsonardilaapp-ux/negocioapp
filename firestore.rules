
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSuperAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    function isBusinessMember(businessId) {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && (
          request.auth.uid == businessId
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId
        );
    }

    // This rule is necessary for resolving custom catalog slugs publicly.
    match /{path=**}/shareConfig/{docId} {
      allow read: if true;
    }

    match /{path=**}/reminders/{reminderId} {
      allow read, create, update, delete, list: if isSuperAdmin();
    }

    match /blog_posts/{postId} {
      allow get, list: if true;

      allow create: if request.auth != null
        && (
          request.resource.data.businessId == request.auth.uid
          || isSuperAdmin()
        );

      allow update, delete: if request.auth != null
        && (
          resource.data.businessId == request.auth.uid
          || isSuperAdmin()
        );
    }

    match /plans/{planId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /globalConfig/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /landing_configs/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow get: if request.auth != null
        && (request.auth.uid == userId || isSuperAdmin());

      allow update: if request.auth != null
        && (request.auth.uid == userId || isSuperAdmin())
        && request.resource.data.role == resource.data.role
        && request.resource.data.businessId == resource.data.businessId;

      allow list: if isSuperAdmin();
      allow create, delete: if isSuperAdmin();
    }

    match /paymentSettings/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;
    }

    match /businesses/{businessId} {
      allow get: if true;
      allow list: if request.auth != null;
      allow create, update, delete: if isBusinessMember(businessId) || isSuperAdmin();

      match /publicData/{docId=**} {
        allow read: if true;
        allow write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /landingPages/{pageId} {
        allow read: if true;
        allow write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /landingConfig/{docId=**} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /products/{productId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /orders/{orderId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /contactForms/{formId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /contactSubmissions/{submissionId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /suggestionRules/{ruleId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /printers/{printerId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /invoiceSettings/{docId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /subscription/{docId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /shareConfig/{docId} {
        // Read is handled by the collection group rule above.
        // This rule only handles writes.
        allow write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /backups/{backupId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /backupSchedules/{scheduleId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /kardexConfig/{docId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /kardexItems/{itemId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /kardexMovimientos/{movimientoId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /notifications/{notificationId} {
        allow read, update, delete: if isBusinessMember(businessId) || isSuperAdmin();
        allow create: if isSuperAdmin();
      }

      match /asientos/{asientoId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /cuentas/{cuentaId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /activosFijos/{activoId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /impuestos/{impuestoId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /declaracionesImpuestos/{declaracionId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /chatbotConfig/main {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();

        match /knowledgeBase/{documentId} {
          allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
        }
      }

      match /chatConversations/{conversationId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();

        match /messages/{messageId} {
          allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
        }
      }

      match /services/{serviceId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }

      match /modules/{moduleId} {
        allow read, write: if isBusinessMember(businessId) || isSuperAdmin();
      }
    }

    match /modules/{moduleId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    match /systemServices/{serviceId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /integrations/{integrationId} {
      allow read: if request.auth != null;
      allow write: if isSuperAdmin();
    }

    match /contactMessages/{messageId} {
      allow read, update, delete: if isSuperAdmin();

      allow create: if request.resource.data.keys().hasOnly([
          'name',
          'email',
          'message',
          'createdAt'
        ])
        && request.resource.data.name is string
        && request.resource.data.email is string
        && request.resource.data.message is string
        && request.resource.data.name.size() > 0
        && request.resource.data.name.size() <= 100
        && request.resource.data.email.size() <= 150
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000;

      match /replies/{replyId} {
        allow read, create: if isSuperAdmin();
      }
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

  