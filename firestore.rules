
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    function isBusinessMember(businessId) {
      // Allows access if the user is the business owner OR a staff member
      // whose user document points to this businessId.
      return request.auth != null && (
        request.auth.uid == businessId ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.businessId == businessId
      );
    }

    // Publicly readable collections
    match /blog_posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /plans/{planId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /globalConfig/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /settings/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // User-specific data
    match /users/{userId} { 
      allow read, write: if request.auth.uid == userId; 
    }
    match /paymentSettings/{userId} {
      allow read, write: if request.auth.uid == userId;
    }

    // Business-related data
    match /businesses/{businessId} {
      allow get: if true; // Business profile can be public
      allow create, update, delete: if isBusinessMember(businessId);

      // Publicly readable subcollections
      match /publicData/{docId=**} {
        allow read: if true;
        allow write: if isBusinessMember(businessId);
      }
      match /landingPages/{pageId} {
        allow read: if true;
        allow write: if isBusinessMember(businessId);
      }

      // Private subcollections with unified member access
      match /products/{productId} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /orders/{orderId} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /contactForms/{formId} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /contactSubmissions/{submissionId} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /suggestionRules/{ruleId} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /printers/{printerId} {
        allow read, write: if isBusinessMember(businessId);
      }
      match /invoiceSettings/{docId} {
         allow read, write: if isBusinessMember(businessId);
      }
      match /subscription/{docId} {
        allow read, write: if isBusinessMember(businessId);
      }

      // Chatbot specific rules
      match /chatbotConfig/main {
        allow read, write: if isBusinessMember(businessId);
        match /knowledgeBase/{documentId} {
            allow read, write: if isBusinessMember(businessId);
        }
      }
      match /chatConversations/{conversationId} {
          allow read, write: if isBusinessMember(businessId);
          match /messages/{messageId} {
              allow read, write: if isBusinessMember(businessId);
          }
      }
    }
    
    // System-level collections (potentially admin-only)
    match /modules/{moduleId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    match /systemServices/{serviceId} { 
      allow read, write: if request.auth != null;
    }
    match /integrations/{integrationId} { 
      allow get, list, write: if request.auth != null;
    }
    
    // Default deny all other paths. This is a security best practice.
    match /{document=**} { 
      allow read, write: if false; 
    }
  }
}
