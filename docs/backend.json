{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Markix platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "businessId": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "status", "createdAt", "lastLogin"]
    },
    "Business": {
      "title": "Business",
      "type": "object",
      "description": "Represents a business tenant.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "referralCode": { "type": "string", "description": "Unique 8-character referral code." },
        "referredByBusinessId": { "type": ["string", "null"], "description": "ID of the business that referred this one." },
        "limitesExtra": {
          "type": "object",
          "properties": {
            "products": { "type": "number" }
          }
        }
      }
    },
    "AffiliateConfig": {
      "title": "AffiliateConfig",
      "type": "object",
      "description": "Stores global settings for the referral program.",
      "properties": {
        "programName": { "type": "string" },
        "rewardReferent": { "type": "number" },
        "rewardReferree": { "type": "number" },
        "maxReferralsPerUser": { "type": ["number", "null"] },
        "isActive": { "type": "boolean" }
      }
    },
    "Referral": {
      "title": "Referral",
      "type": "object",
      "description": "Represents a referral connection between two businesses.",
      "properties": {
        "referentBusinessId": { "type": "string" },
        "referreeBusinessId": { "type": "string" },
        "referralCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending_payment", "confirmed", "rejected"] },
        "paidConfirmedAt": { "type": ["string", "null"], "format": "date-time" },
        "referentRewardGranted": { "type": "boolean" },
        "referreeRewardGranted": { "type": "boolean" },
        "paymentRail": { "type": ["string", "null"] },
        "origin": { "type": "string" },
        "adminResponsibleId": { "type": ["string", "null"] },
        "manualNote": { "type": ["string", "null"] }
      }
    },
    "ExtraCapacityLog": {
      "title": "ExtraCapacityLog",
      "type": "object",
      "description": "Log of extra capacity granted to businesses.",
      "properties": {
        "businessId": { "type": "string" },
        "businessName": { "type": "string" },
        "amount": { "type": "number" },
        "reason": { "type": "string" },
        "origin": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "ProductAlert": {
      "title": "ProductAlert",
      "type": "object",
      "description": "Represents an alert for a product with low rating.",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "rating": { "type": "number" },
        "ratingCount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/businesses/{businessId}",
        "definition": {
          "entityName": "Business",
          "schema": { "$ref": "#/backend/entities/Business" },
          "description": "Main business document."
        }
      },
      {
        "path": "/adminConfig/affiliates",
        "definition": {
          "entityName": "AffiliateConfig",
          "schema": { "$ref": "#/backend/entities/AffiliateConfig" },
          "description": "Global configuration for the affiliate program."
        }
      },
      {
        "path": "/referrals/{referralId}",
        "definition": {
          "entityName": "Referral",
          "schema": { "$ref": "#/backend/entities/Referral" },
          "description": "Logs of referrals and their reward status."
        }
      },
      {
        "path": "/extraCapacityLogs/{logId}",
        "definition": {
          "entityName": "ExtraCapacityLog",
          "schema": { "$ref": "#/backend/entities/ExtraCapacityLog" },
          "description": "Audit logs for extra capacity granted."
        }
      },
      {
        "path": "/businesses/{businessId}/productAlerts/{alertId}",
        "definition": {
          "entityName": "ProductAlert",
          "schema": { "$ref": "#/backend/entities/ProductAlert" },
          "description": "Stores low rating alerts for business products."
        }
      }
    ]
  }
}
