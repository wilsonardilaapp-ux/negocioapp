
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Zentry platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "businessId": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "status", "createdAt", "lastLogin"]
    },
    "DirectoryAd": {
      "title": "DirectoryAd",
      "type": "object",
      "description": "Represents an advertisement in the business directory.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "linkUrl": { "type": "string", "format": "uri" },
        "format": { "type": "string", "enum": ["google_display", "meta_feed", "meta_story"] },
        "position": { "type": "string", "enum": ["top", "mid", "grid", "sidebar"] },
        "active": { "type": "boolean" },
        "views": { "type": "number" },
        "clicks": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/directoryAds/{adId}",
        "definition": {
          "entityName": "DirectoryAd",
          "schema": { "$ref": "#/backend/entities/DirectoryAd" },
          "description": "Stores advertisements for the directory."
        }
      }
    ]
  }
}
