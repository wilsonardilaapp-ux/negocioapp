{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user of the Zentry platform.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string" },
        "status": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "businessId": { "type": "string" }
      },
      "required": ["id", "name", "email", "role", "status", "createdAt", "lastLogin"]
    },
    "Business": {
      "title": "Business",
      "type": "object",
      "description": "Represents a business tenant.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "referralCode": { "type": "string", "description": "Unique 8-character referral code." },
        "referredByBusinessId": { "type": ["string", "null"], "description": "ID of the business that referred this one." }
      }
    },
    "AffiliateConfig": {
      "title": "AffiliateConfig",
      "type": "object",
      "description": "Stores global settings for the referral program.",
      "properties": {
        "programName": { "type": "string" },
        "rewardReferent": { "type": "number" },
        "rewardReferree": { "type": "number" },
        "maxReferralsPerUser": { "type": ["number", "null"] },
        "isActive": { "type": "boolean" }
      }
    },
    "DirectoryAd": {
      "title": "DirectoryAd",
      "type": "object",
      "description": "Represents an advertisement in the business directory.",
      "properties": {
        "id": { "type": "string" },
        "title": { "type": "string" },
        "imageUrl": { "type": "string", "format": "uri" },
        "linkUrl": { "type": "string", "format": "uri" },
        "format": { "type": "string", "enum": ["google_display", "meta_feed", "meta_story"] },
        "position": { "type": "string", "enum": ["top", "mid", "grid", "sidebar"] },
        "active": { "type": "boolean" },
        "views": { "type": "number" },
        "clicks": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "DirectoryRating": {
      "title": "DirectoryRating",
      "type": "object",
      "description": "Represents a user rating for a business in the directory.",
      "properties": {
        "id": { "type": "string" },
        "businessId": { "type": "string" },
        "businessName": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "published", "hidden", "rejected", "reported"] },
        "adminResponse": { "type": "string" },
        "businessResponse": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "businessId", "userId", "rating", "comment", "status", "createdAt", "updatedAt"]
    },
    "ProductAlert": {
      "title": "ProductAlert",
      "type": "object",
      "description": "Represents an alert for a product with low rating.",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "rating": { "type": "number" },
        "ratingCount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "reviewed", "resolved"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Stores user profiles."
        }
      },
      {
        "path": "/businesses/{businessId}",
        "definition": {
          "entityName": "Business",
          "schema": { "$ref": "#/backend/entities/Business" },
          "description": "Main business document."
        }
      },
      {
        "path": "/adminConfig/affiliates",
        "definition": {
          "entityName": "AffiliateConfig",
          "schema": { "$ref": "#/backend/entities/AffiliateConfig" },
          "description": "Global configuration for the affiliate program."
        }
      },
      {
        "path": "/directoryAds/{adId}",
        "definition": {
          "entityName": "DirectoryAd",
          "schema": { "$ref": "#/backend/entities/DirectoryAd" },
          "description": "Stores advertisements for the directory."
        }
      },
      {
        "path": "/directoryRatings/{ratingId}",
        "definition": {
          "entityName": "DirectoryRating",
          "schema": { "$ref": "#/backend/entities/DirectoryRating" },
          "description": "Stores user ratings for businesses."
        }
      },
      {
        "path": "/businesses/{businessId}/productAlerts/{alertId}",
        "definition": {
          "entityName": "ProductAlert",
          "schema": { "$ref": "#/backend/entities/ProductAlert" },
          "description": "Stores low rating alerts for business products."
        }
      }
    ]
  }
}